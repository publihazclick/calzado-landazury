<section id="contacto" class="mt-12 md:mt-20 px-4 md:px-8 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-8 md:mb-12">
      <h3 class="text-xl md:text-2xl lg:text-3xl font-extrabold text-slate-900 tracking-tight">
        Contactanos
      </h3>
      <p class="mt-2 text-slate-500 text-sm md:text-base max-w-md mx-auto">
        Estamos para ayudarte. Visitanos o escribenos por cualquiera de nuestros canales.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Ubicacion -->
      <div class="rounded-xl bg-white border border-slate-100 shadow-sm p-6 md:p-8 flex flex-col items-center text-center gap-4">
        <div class="flex items-center justify-center size-14 rounded-full bg-primary/10 text-primary">
          <span class="material-symbols-outlined text-2xl">location_on</span>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 text-base">Nuestra Tienda</h4>
          <p class="text-slate-500 text-sm mt-1 leading-relaxed">
            Ave 13 #10-62, El Llano<br/>Cucuta, Colombia
          </p>
        </div>
        <a
          href="https://www.google.com/maps/search/Ave+13+%2310-62+El+Llano+Cucuta"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary text-sm font-bold hover:underline inline-flex items-center gap-1"
        >
          Ver en mapa
          <span class="material-symbols-outlined text-sm">open_in_new</span>
        </a>
      </div>

      <!-- Telefono -->
      <div class="rounded-xl bg-white border border-slate-100 shadow-sm p-6 md:p-8 flex flex-col items-center text-center gap-4">
        <div class="flex items-center justify-center size-14 rounded-full bg-primary/10 text-primary">
          <span class="material-symbols-outlined text-2xl">call</span>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 text-base">Telefono</h4>
          <p class="text-slate-500 text-sm mt-1">Llamanos o escribenos</p>
        </div>
        <a
          href="tel:+573001234567"
          class="text-primary text-sm font-bold hover:underline"
        >
          +57 300 123 4567
        </a>
      </div>

      <!-- Horario -->
      <div class="rounded-xl bg-white border border-slate-100 shadow-sm p-6 md:p-8 flex flex-col items-center text-center gap-4">
        <div class="flex items-center justify-center size-14 rounded-full bg-primary/10 text-primary">
          <span class="material-symbols-outlined text-2xl">schedule</span>
        </div>
        <div>
          <h4 class="font-bold text-slate-900 text-base">Horario</h4>
          <p class="text-slate-500 text-sm mt-1 leading-relaxed">
            Lun - Sab: 9:00 AM - 7:00 PM<br/>Dom: 10:00 AM - 4:00 PM
          </p>
        </div>
      </div>
    </div>

    <!-- Formulario de contacto -->
    <div class="mt-8 md:mt-12 rounded-xl bg-white border border-slate-100 shadow-sm p-6 md:p-10 max-w-2xl mx-auto">
      <h4 class="font-bold text-lg text-slate-900 mb-6 text-center">Enviar un mensaje</h4>
      <form class="flex flex-col gap-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input
            type="text"
            placeholder="Nombre"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
          />
          <input
            type="email"
            placeholder="Correo electronico"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
          />
        </div>
        <input
          type="text"
          placeholder="Asunto"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
        />
        <textarea
          rows="4"
          placeholder="Tu mensaje..."
          class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-none"
        ></textarea>
        <button
          type="submit"
          class="w-full md:w-auto md:self-end px-8 py-3 rounded-full bg-primary text-white font-bold text-sm hover:scale-105 active:scale-95 transition-transform shadow-lg shadow-primary/20"
        >
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</section>
